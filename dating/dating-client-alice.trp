import lists
import declassifyutil

let 
   val lev = `{alice}` 
   val name = "Alice" raisedTo lev
   val year = 1994 raisedTo lev
   val gender = true raisedTo lev
   val interests = ["baking", "reading", "football"] raisedTo lev
   val profile = (lev, name, year, gender, interests)
   


   fun agent (levRcv, nameRcv, yearRcv, genderRcv, interestsRcv) =
      let val older = declassify_with_block(year > yearRcv, authority, levRcv)
         val likes = declassify_with_block(elem "football" interestsRcv, authority, levRcv)
         val preference = declassify_with_block(older andalso likes, authority, levRcv)
         val maybeProfile = if preference
            then declassifydeep(profile, authority, levRcv)
            else ()
      in (preference, maybeProfile)
      end

    fun loop matches =
        let val match = receive [ hn ("NEWMATCH", data) => data]
            val _ = printWithLabels("NEW MATCH")
            val _ = print match
            val allMatches = append matches [match]
        in loop allMatches
        end

    fun main () =
        let val pid = self()
            val message = ("NEWPROFILE", (profile, agent, pid))
            val datingServer = whereis ("QmZuTiRquPhNu2VsEpUAvDrkMmNYeCm18viY8YsLbm7Kir", "datingServer")
            val _ = send(datingServer, message)
        in loop []
        end

in main ()
end
